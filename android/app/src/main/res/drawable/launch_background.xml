<?xml version="1.0" encoding="utf-8"?>
<!-- The launch window the OS shows before Flutter's first frame. Brand indigo,
     matching the Flutter BrandSplash, so there is no white flash on cold start —
     the animated logo materialises on the same indigo field. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@color/brand_indigo" />
</layer-list>
